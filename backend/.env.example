# .env.example
FRONTEND_URL=http://localhost:3000

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_db

# Redis connection (используется и для Celery, и для прямого доступа)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# Database tables
DATA_TABLE=results_data
COEFFS_WITH_INTERCEPT_TABLE=results_coeffs_with_intercept
COEFFS_NO_INTERCEPT_TABLE=results_coeffs_no_intercept
ENSEMBLE_INFO_TABLE=results_ensemble_info

# BASE+ specific tables
BASEPLUS_TABULAR_ENSEMBLE_INFO_TABLE=baseplus_tabular_ensemble_info
BASEPLUS_FEATURE_IMPORTANCE_TABLE=baseplus_feature_importance

# Other tables
ADJUSTMENTS_TABLE=adjustments
EXCHANGE_RATE_TABLE=exchange_rates


# Keycloak (OIDC)
# Base URL reachable from the backend container.
# If backend runs in docker-compose with a 'keycloak' service, this could be http://keycloak:8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=nwc

# ClientId that your frontend uses to obtain access tokens
KEYCLOAK_CLIENT_ID=nwc-frontend

# Optional overrides (normally not needed)
# KEYCLOAK_ISSUER=http://localhost:8080/realms/nwc
# KEYCLOAK_JWKS_URL=http://localhost:8080/realms/nwc/protocol/openid-connect/certs
# KEYCLOAK_ALGORITHMS=RS256
# KEYCLOAK_LEEWAY_SECONDS=60

SECRET_WORD=admin